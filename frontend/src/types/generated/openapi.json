        "type": "string",
        "enum": [
          "correct",
          "incorrect",
          "partial",
          "skipped",
          "unresolved"
        ],
        "title": "CheckpointEvaluationStatus"
      },
      "ExerciseCandidate": {
        "properties": {
          "exercise_ref": {
            "type": "string",
            "maxLength": 200,
            "minLength": 1,
            "title": "Exercise Ref"
          },
          "prompt_excerpt": {
            "type": "string",
            "maxLength": 600,
            "minLength": 1,
            "title": "Prompt Excerpt"
          },
          "hidden_answer_ref": {
            "anyOf": [
              {
                "type": "string",
