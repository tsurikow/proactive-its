            "type": "string",
            "enum": [
              "exercise",
              "checkpoint",
              "question"
            ],
            "title": "Item Type"
          },
          "hidden_answer_ref": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 200
              },
              {
                "type": "null"
              }
            ],
            "title": "Hidden Answer Ref"
          },
          "answer_source_excerpt": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 700
              },
