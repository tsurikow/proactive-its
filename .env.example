OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=bge-m3:latest
EMBEDDING_MAX_INPUT_TOKENS=8192
EMBEDDING_NUM_CTX=8192
EMBEDDING_BATCH_SIZE=8

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=calc1_chunks
QDRANT_SECTIONS_COLLECTION=calc1_sections

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/proactive_its
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
BOOK_JSON_PATH=data/book.json

RAG_TOP_K_FETCH=24
RAG_FINAL_K=6
RAG_MIN_SCORE=0.2
RAG_MIN_EVIDENCE_CHARS=180
RAG_MIN_TERM_OVERLAP=0.28
RAG_GENERATION_TIMEOUT_SECONDS=45
CHUNK_TARGET_TOKENS=450
CHUNK_OVERLAP_TOKENS=60
ENABLE_RETRIEVAL_DEBUG=true

LESSON_GEN_ENABLED=true
LESSON_GEN_FORMAT_VERSION=6
LESSON_MAX_SECTION_SECONDS=90

APP_HOST=0.0.0.0
APP_PORT=8000
