APP_ENV=dev
APP_DEBUG=false
SERVICE_NAME=proactive-its-api
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_PUBLIC_URL=http://localhost
ALLOWED_HOSTS=localhost,127.0.0.1
LOG_LEVEL=INFO
LOG_FORMAT=json
CORS_ALLOW_ORIGINS=http://localhost,http://127.0.0.1
AUTH_SECRET_KEY=change-me-auth-secret-key
AUTH_COOKIE_NAME=proactive_its_session
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_HOURS=336
AUTH_RESET_TOKEN_TTL_MINUTES=60
AUTH_DEV_LOG_RESET_LINKS=true
AUTH_RESET_ENABLED=true
AUTH_LOGIN_ATTEMPT_WINDOW_SECONDS=300
AUTH_LOGIN_ATTEMPT_LIMIT=10
AUTH_SIGNUP_ATTEMPT_WINDOW_SECONDS=900
AUTH_SIGNUP_ATTEMPT_LIMIT=5
AUTH_RESET_ATTEMPT_WINDOW_SECONDS=900
AUTH_RESET_ATTEMPT_LIMIT=5
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_STARTTLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20
LOGFIRE_ENABLED=false
LOGFIRE_TOKEN=
LOGFIRE_SERVICE_NAME=proactive-its-api
LOGFIRE_ENVIRONMENT=dev
LOGFIRE_CAPTURE_CONTENT=false
WEB_PUBLISH_PORT=80

POSTGRES_DB=proactive_its
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_INTERNAL_PORT=5432
POSTGRES_PUBLISH_PORT=5432
POSTGRES_VOLUME_NAME=proactive_its_postgres_data

QDRANT_INTERNAL_PORT=6333
QDRANT_PUBLISH_PORT=6333
QDRANT_VOLUME_NAME=proactive_its_qdrant_storage

RABBITMQ_DEFAULT_USER=proactive
RABBITMQ_DEFAULT_PASS=change-me-rabbitmq-password
RABBITMQ_INTERNAL_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_PUBLISH_PORT=5672
RABBITMQ_MANAGEMENT_PUBLISH_PORT=15672

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
TEACHER_REASONING_MODEL=google/gemini-2.5-flash
TEACHER_SECTION_UNDERSTANDING_MODEL=
TEACHER_ANSWER_CHECK_MODEL=
TEACHER_FEEDBACK_MODEL=
RAG_ANSWER_MODEL=

EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=baai/bge-m3
EMBEDDING_INDEX_CONCURRENCY=4
EMBEDDING_MAX_INPUT_TOKENS=8192
EMBEDDING_NUM_CTX=
EMBEDDING_BATCH_SIZE=8

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=calc1_chunks
QDRANT_SECTIONS_COLLECTION=calc1_sections

DATABASE_URL=postgresql+asyncpg://postgres:change-me-postgres-password@localhost:5432/proactive_its
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
BOOK_JSON_PATH=data/book.json
DOCUMENTS_JSON_PATH=data/documents.jsonl
MEDIA_DIR=data/media
RABBITMQ_URL=amqp://proactive:change-me-rabbitmq-password@localhost:5672//

RAG_TOP_K_FETCH=24
RAG_FINAL_K=6
RAG_MIN_SCORE=0.2
RAG_MIN_EVIDENCE_CHARS=180
RAG_MIN_TERM_OVERLAP=0.28
RAG_GENERATION_TIMEOUT_SECONDS=45
RAG_QUERY_REWRITE_MODEL=
CHUNK_TARGET_TOKENS=450
CHUNK_OVERLAP_TOKENS=60
ENABLE_RETRIEVAL_DEBUG=true

LESSON_GEN_ENABLED=true
LESSON_GEN_FORMAT_VERSION=6
LESSON_MAX_SECTION_SECONDS=90

DURABLE_CHAT_ENABLED=false
CHAT_WORKER_QUEUE=chat_generation

VITE_API_BASE_URL=/v1
VITE_REQUEST_TIMEOUT_MS=90000
VITE_AUTH_RESET_ENABLED=true
VITE_DEV_HOST=127.0.0.1
VITE_DEV_PORT=5173
VITE_DEV_API_PROXY_TARGET=http://localhost:8000
VITE_DEV_MEDIA_PROXY_TARGET=http://localhost:8000

# DVC bootstrap example:
# DVC remote add -d production s3://your-bucket/proactive-its-data
# DVC remote modify production endpointurl https://your-s3-endpoint.example

# Local/dev note:
# docker-compose.dev.yml overrides EMBEDDING_BASE_URL to a host-local runtime
# (for example Ollama at http://host.docker.internal:11434/v1).
